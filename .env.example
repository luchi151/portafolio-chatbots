# ─── App ────────────────────────────────────────────────────────────────────────
# Base URL for OG/Twitter meta and canonical links. Set to your Vercel domain.
NEXT_PUBLIC_APP_URL=https://portafolio-chatbots.vercel.app

# ─── Database (Supabase) ────────────────────────────────────────────────────────
# Use the Transaction pooler URL (port 6543) — required for serverless functions.
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ─── Supabase ───────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_ prefix makes these available in browser components at build time.
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbG...

# ─── Auth ───────────────────────────────────────────────────────────────────────
# Random secret for signing demo JWTs. Generate with: openssl rand -base64 32
JWT_SECRET=your-random-secret-here

# ─── LLMs ───────────────────────────────────────────────────────────────────────
# At least one is required. DeepSeek is tried first; Groq is the fallback.
DEEPSEEK_API_KEY=
GROQ_API_KEY=

# ─── Document parsing ───────────────────────────────────────────────────────────
# Optional: without this, /api/docs/parse returns realistic demo content instead.
LLAMAPARSE_API_KEY=

# ─── Voice ──────────────────────────────────────────────────────────────────────
# Optional: without Deepgram the browser's Web Speech API is used for STT.
# Without ElevenLabs the TTS feature is disabled (no audio playback in voicebot).
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# ─── RAG (support chat demo) ────────────────────────────────────────────────────
# Required for /demos/support: generates embeddings for the knowledge base and
# for incoming queries. Free tier at voyageai.com. Without it, the demo shows a
# "no configurada" message instead of crashing.
VOYAGE_API_KEY=

# ─── Notifications (escalation alerts) ──────────────────────────────────────────
# Optional: without these, escalations are only recorded in the DB (no external alert).
SLACK_WEBHOOK_URL=
RESEND_API_KEY=
ESCALATION_NOTIFY_EMAIL=
ESCALATION_FROM_EMAIL=onboarding@resend.dev
